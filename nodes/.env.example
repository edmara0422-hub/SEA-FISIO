# ===================
# ASSISTENTE IA LOCAL
# ===================
NEXT_PUBLIC_AI_PROVIDER=local

# ===================
# VECTOR DB (PINECONE)
# ===================
PINECONE_API_KEY=your_pinecone_key_here
PINECONE_ENVIRONMENT=gcp-starter
NEXT_PUBLIC_PINECONE_INDEX=clinical-knowledge

# ===================
# REAL-TIME (LIVEBLOCKS)
# ===================
NEXT_PUBLIC_LIVEBLOCKS_PUBLIC_KEY=your_liveblocks_key_here
LIVEBLOCKS_SECRET_KEY=your_liveblocks_secret_here

# ===================
# MESSAGE QUEUES (BULL)
# ===================
REDIS_URL=redis://localhost:6379
BULL_QUEUE_CALCULATIONS=vm-calculations
BULL_QUEUE_EXPORTS=pdf-exports
BULL_QUEUE_NOTIFICATIONS=notifications

# ===================
# FEATURE FLAGS (LAUNCHDARKLY)
# ===================
NEXT_PUBLIC_LAUNCHDARKLY_CLIENT_ID=your_ld_client_id_here
LAUNCHDARKLY_SDK_KEY=your_ld_sdk_key_here

# ===================
# MONITORING (SENTRY + POSTHOG)
# ===================
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn_here
SENTRY_AUTH_TOKEN=your_sentry_token_here
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_key_here
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ===================
# EDGE FUNCTIONS (VERCEL)
# ===================
VERCEL_ENV=preview
VERCEL_URL=http://localhost:3000

# ===================
# DATABASE (SUPABASE)
# ===================
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_key_here

# ===================
# PWA
# ===================
NEXT_PUBLIC_APP_NAME=SEA - Sistema de Estudo Avançado
NEXT_PUBLIC_APP_DESCRIPTION=Plataforma enterprise para simulações clínicas

# ===================
# AI GATEWAY (VERCEL)
# ===================
AI_GATEWAY_API_KEY=your_ai_gateway_key_here
