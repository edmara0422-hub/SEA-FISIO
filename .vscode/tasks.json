{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "SEA Dev Server",
			"type": "shell",
			"command": "npm run dev",
			"isBackground": true,
			"runOptions": {
				"runOn": "folderOpen"
			},
			"problemMatcher": {
				"pattern": {
					"regexp": "^(?!\\s*$)",
					"file": 0,
					"location": 1,
					"message": 2
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": "▲ Next.js",
					"endsPattern": "✓ Ready in"
				}
			},
			"presentation": {
				"reveal": "silent",
				"panel": "dedicated"
			}
		},
		{
			"label": "Fix Dependencies",
			"type": "shell",
			"command": "rm -rf node_modules package-lock.json && npm install",
			"problemMatcher": []
		},
		{
			"label": "TypeCheck",
			"type": "shell",
			"command": "npx tsc --noEmit --pretty false 2>&1 | grep 'error TS' | head -90",
			"problemMatcher": [
				"$tsc"
			]
		}
	]
}