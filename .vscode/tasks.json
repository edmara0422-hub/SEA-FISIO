{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "SEA Dev Server",
			"type": "shell",
			"command": "npm run dev",
			"isBackground": true,
			"problemMatcher": {
				"pattern": {
					"regexp": "^(?!\\s*$)",
					"file": 0,
					"location": 1,
					"message": 2
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": "▲ Next.js",
					"endsPattern": "✓ Ready in"
				}
			},
			"presentation": {
				"reveal": "silent",
				"panel": "dedicated"
			}
		},
		{
			"label": "Fix Dependencies",
			"type": "shell",
			"command": "bash ./fix-deps.sh",
			"problemMatcher": []
		},
		{
			"label": "TypeCheck",
			"type": "shell",
			"command": "npm run typecheck",
			"problemMatcher": [
				"$tsc"
			]
		},
		{
			"label": "TS Errors Quick",
			"type": "shell",
			"command": "npm run typecheck",
			"problemMatcher": [
				"$tsc"
			]
		}
	]
}
